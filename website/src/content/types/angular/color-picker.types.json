{
  "Area": {
    "props": {
      "xChannel": {
        "type": "'hue' | 'saturation' | 'brightness' | 'lightness' | 'red' | 'green' | 'blue' | 'alpha'",
        "isRequired": false,
        "kind": "input",
        "description": "The horizontal channel controlled by the color area."
      },
      "yChannel": {
        "type": "'hue' | 'saturation' | 'brightness' | 'lightness' | 'red' | 'green' | 'blue' | 'alpha'",
        "isRequired": false,
        "kind": "input",
        "description": "The vertical channel controlled by the color area."
      }
    }
  },
