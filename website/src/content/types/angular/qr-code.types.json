{
  "Root": {
    "props": {
      "defaultValue": {
        "type": "string",
        "isRequired": false,
        "kind": "input",
        "description": "The initial value to encode when uncontrolled."
      },
      "encoding": {
        "type": "QrCodeGenerateOptions",
        "isRequired": false,
        "kind": "input",
        "description": "The QR code encoding options."
      },
      "id": {
        "type": "string",
        "isRequired": false,
        "kind": "input",
        "description": "The unique identifier of the QR code."
      },
      "ids": {
        "type": "Partial<{ root: string; frame: string }>",
        "isRequired": false,
        "kind": "input",
        "description": "The ids of the QR code elements. Useful for composition."
      },
      "pixelSize": {
        "type": "number",
        "isRequired": false,
        "kind": "input",
        "description": "The pixel size of the QR code."
      },
      "value": {
        "type": "string",
        "isRequired": false,
        "kind": "model",
        "description": "The controlled value to encode."
      }
    }
  },
  "RootProvider": {
    "props": {
      "value": {
        "type": "UseQrCodeReturn",
        "isRequired": true,
        "kind": "required-input",
        "description": "The QR code machine returned by useQrCode()."
      }
    }
  },
  "Frame": {
    "props": {}
  },
  "Pattern": {
    "props": {}
  },
  "Overlay": {
    "props": {}
  },
  "DownloadTrigger": {
    "props": {
      "fileName": {
        "type": "string",
        "isRequired": true,
        "kind": "required-input",
        "description": "The name of the file."
      },
      "mimeType": {
        "type": "DataUrlType",
        "isRequired": true,
        "kind": "required-input",
        "description": "The mime type of the image."
      },
      "quality": {
        "type": "number",
        "isRequired": false,
        "kind": "input",
        "description": "The quality of the image."
      }
    }
  },
  "Context": {
    "props": {}
  }
}
