{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./out-tsc",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ark-ui/angular/avatar": ["avatar/public-api.ts"],
      "@ark-ui/angular/clipboard": ["clipboard/public-api.ts"],
      "@ark-ui/angular/collapsible": ["src/collapsible/public-api.ts"],
      "@ark-ui/angular/color-picker": ["src/color-picker/public-api.ts"],
      "@ark-ui/angular/collection": ["src/collection/public-api.ts"],
      "@ark-ui/angular/combobox": ["combobox/public-api.ts"],
      "@ark-ui/angular/date-input": ["src/date-input/public-api.ts"],
      "@ark-ui/angular/date-picker": ["src/date-picker/public-api.ts"],
      "@ark-ui/angular/dialog": ["src/dialog/public-api.ts"],
      "@ark-ui/angular/drawer": ["src/drawer/public-api.ts"],
      "@ark-ui/angular/editable": ["editable/public-api.ts"],
      "@ark-ui/angular/field": ["field/public-api.ts"],
      "@ark-ui/angular/fieldset": ["fieldset/public-api.ts"],
      "@ark-ui/angular/file-upload": ["file-upload/public-api.ts"],
      "@ark-ui/angular/hover-card": ["src/hover-card/public-api.ts"],
      "@ark-ui/angular/image-cropper": ["src/image-cropper/public-api.ts"],
      "@ark-ui/angular/json-tree-view": ["src/json-tree-view/public-api.ts"],
      "@ark-ui/angular/listbox": ["listbox/public-api.ts"],
      "@ark-ui/angular/menu": ["src/menu/public-api.ts"],
      "@ark-ui/angular/navigation-menu": ["src/navigation-menu/public-api.ts"],
      "@ark-ui/angular/number-input": ["number-input/public-api.ts"],
      "@ark-ui/angular/password-input": ["password-input/public-api.ts"],
      "@ark-ui/angular/pin-input": ["pin-input/public-api.ts"],
      "@ark-ui/angular/popover": ["src/popover/public-api.ts"],
      "@ark-ui/angular/portal": ["src/portal/public-api.ts"],
      "@ark-ui/angular/presence": ["src/presence/public-api.ts"],
      "@ark-ui/angular/progress": ["progress/public-api.ts"],
      "@ark-ui/angular/qr-code": ["src/qr-code/public-api.ts"],
      "@ark-ui/angular/select": ["select/public-api.ts"],
      "@ark-ui/angular/signature-pad": ["src/signature-pad/public-api.ts"],
      "@ark-ui/angular/tags-input": ["tags-input/public-api.ts"],
      "@ark-ui/angular/toggle": ["toggle/public-api.ts"],
      "@ark-ui/angular/tooltip": ["src/tooltip/public-api.ts"],
      "@ark-ui/angular/tree-view": ["src/tree-view/public-api.ts"],
      "@ark-ui/angular/src/_zag": ["src/_zag/public-api.ts"],
      "@ark-ui/angular/src/_zag/apply-ark-props": ["src/_zag/apply-ark-props.ts"],
      "@ark-ui/angular/src/_zag/use-machine": ["src/_zag/use-machine.ts"],
      "@ark-ui/angular/src/internal": ["src/internal/public-api.ts"],
      "@ark-ui/angular/src/internal/id": ["src/internal/id.ts"],
      "@ark-ui/angular/src/internal/types": ["src/internal/types.ts"],
      "@ark-ui/angular/src/presence": ["src/presence/public-api.ts"],
      "@ark-ui/angular/src/providers/environment": ["src/providers/environment/public-api.ts"],
      "@ark-ui/angular/src/providers/locale": ["src/providers/locale/public-api.ts"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"]
  },
  "angularCompilerOptions": {
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "include": [
    "src/**/*.ts",
    "avatar/**/*.ts",
    "clipboard/**/*.ts",
    "combobox/**/*.ts",
    "editable/**/*.ts",
    "field/**/*.ts",
    "fieldset/**/*.ts",
    "file-upload/**/*.ts",
    "listbox/**/*.ts",
    "number-input/**/*.ts",
    "password-input/**/*.ts",
    "pin-input/**/*.ts",
    "progress/**/*.ts",
    "select/**/*.ts",
    "tags-input/**/*.ts",
    "toggle/**/*.ts"
  ],
  "exclude": ["**/*.spec.ts", "**/setup-test.ts"]
}
