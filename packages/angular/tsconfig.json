{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./out-tsc",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ark-ui/angular/src/presence": ["src/presence/public-api.ts"],
      "@ark-ui/angular/src/providers/environment": ["src/providers/environment/public-api.ts"],
      "@ark-ui/angular/src/providers/locale": ["src/providers/locale/public-api.ts"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"]
  },
  "angularCompilerOptions": {
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "include": ["src/**/*.ts", "avatar/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/setup-test.ts"]
}
